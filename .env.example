# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/configdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=configdb

# Security
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=kullaniciadi/config-backups

# Redis
REDIS_URL=redis://redis:6379/0

# SSH
SSH_TIMEOUT=30

# App environment — 'development' logs reset token to console when SMTP not configured
ENVIRONMENT=production
FRONTEND_URL=http://localhost

# Bootstrap — creates the first super_administrator on first migration run (optional)
# Set these before running 'alembic upgrade head' for the first time.
# Leave empty after first run; values in DB take precedence.
INITIAL_SUPERADMIN_USERNAME=admin
INITIAL_SUPERADMIN_PASSWORD=changeme123

# SMTP (optional — for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
